{
    "name": "dakshraman/laravel-ai-debugger",
    "description": "AI Debugging Assistant for Laravel using local CLI tools (Claude, Gemini, Copilot, Codex)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "debugging",
        "claude",
        "gemini",
        "copilot",
        "codex"
    ],
    "authors": [
        {
            "name": "dakshraman"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Dakshraman\\AIDebugger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dakshraman\\AIDebugger\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dakshraman\\AIDebugger\\AIDebuggerServiceProvider"
            ],
            "aliases": {
                "AIDebugger": "Dakshraman\\AIDebugger\\Facades\\AIDebugger"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
